<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>결제 내역 - 관리 시스템</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <a href="/" class="home-link">🏠 메인 대시보드로 돌아가기</a>
    <div class="list-container">
        <header>
            <h1>💳 전체 결제 내역</h1>
            <span style="background:#ff9500; color:white; padding:4px 12px; border-radius:20px; font-size:13px;">누적 <%= payments.length %>건</span>
        </header>
        <table>
            <thead>
                <tr>
                    <th>결제번호</th>
                    <th>주문자명</th>
                    <th>총 결제금액</th>
                    <th>결제 시간</th>
                    <th>상세</th>
                </tr>
            </thead>
            <tbody>
                <% payments.forEach(p => { %>
                <tr>
                    <td><%= p.payment_no %></td>
                    <td><%= p.member_name %></td>
                    <td>
                        <span style="font-weight: bold;">
                            <%= p.total_price ? p.total_price.toLocaleString() : '0' %>원
                        </span>
                    </td>
                    <td style="color:#666; font-size: 13px;">
                        <%= p.payment_date ? new Date(p.payment_date).toLocaleString('ko-KR') : '-' %>
                    </td>
                    <td><a href="/payments/<%= p.payment_no %>" class="btn-detail">내역 보기</a></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>