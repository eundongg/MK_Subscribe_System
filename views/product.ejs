<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>상품 목록 - 관리 시스템</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <a href="/" class="home-link">🏠 메인 대시보드로 돌아가기</a>
    <% const imageMap = {
        '매경e신문': '/image/매경e신문.png',
        '매경이코노미': '/image/매경이코노미.png',
        '매경럭스멘': '/image/매경럭스멘.png'
    }; %>
    <div class="list-container">
        <header>
            <h1>📦 상품 목록 관리</h1>
            <span class="count-badge">판매중 <%= products.length %>종</span>
        </header>
        <section class="product-grid">
            <% products.forEach((p) => { %>
                <article class="product-card">
                    <img
                        class="product-thumb"
                        src="<%= imageMap[p.product_name] || '/image/매경e신문.png' %>"
                        alt="<%= p.product_name %>"
                    />
                    <div class="product-body">
                        <h2 class="product-name"><%= p.product_name %></h2>
                        <p class="product-desc"><%= p.description || '상품 설명이 아직 등록되지 않았습니다.' %></p>
                        <div class="product-meta">
                            <span class="price-tag"><%= p.price.toLocaleString() %>원</span>
                            <span><%= p.duration_months || '-' %>개월</span>
                        </div>
                    </div>
                </article>
            <% }) %>
        </section>
    </div>
</body>
</html>