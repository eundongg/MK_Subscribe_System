<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>상세 내역 - 관리 시스템</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <a href="/payments" class="back-link">← 결제 목록으로 돌아가기</a>
    <div class="list-container">
        <h2 style="border-bottom: 2px solid var(--primary); padding-bottom: 10px;">🧾 상세 영수증 (No. <%= paymentNo %>)</h2>
        <% items.forEach(item => { %>
            <div class="item-row">
                <div class="item-header">
                    <span class="product-no">구매한 상품 이름: <%= item.product_name %></span>
                    <span class="price"><%= item.price_at_billing.toLocaleString() %>원</span>
                </div>
                <div class="date-info">
                    📅 구독 기간: <%= new Date(item.start_date).toLocaleDateString() %> ~ <%= new Date(item.end_date).toLocaleDateString() %>
                </div>
            </div>
        <% }) %>
    </div>
</body>
</html>